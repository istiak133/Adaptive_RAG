# =====================================================================
# Git ignore rules
# =====================================================================


# ── Secrets ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key


# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/


# ── Virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/
ENV/


# ── Generated runtime data ───────────────────────────────────────────
kb/chromadb/*
!kb/chromadb/.gitkeep
logs/*.log
logs/*.log.*
*.db
*.sqlite
*.sqlite3


# ── Outputs ──────────────────────────────────────────────────────────
# Track the sample JSON deliverables so reviewers can see them without
# running the LLM. Other generated files (logs, temp) are still ignored.
outputs/**/*.log
outputs/**/*.tmp
outputs/manual_run/
!outputs/scenario_a/.gitkeep
!outputs/scenario_b_iter1/.gitkeep
!outputs/scenario_b_iter2/.gitkeep
!outputs/scenario_b_iter3/.gitkeep


# ── IDE & editor files ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~


# ── OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# ── Docker volumes ───────────────────────────────────────────────────
pgdata/


# ── Temporary / scratch files ────────────────────────────────────────
.tmp_pdf_text/
.sixth/
*.tmp
*.bak
*.orig


# ── Personal study notes (NOT for reviewer) ──────────────────────────
notes/
IMPLEMENTATION_GUIDE.md
chat_history_*.txt
chat_overview_analysis.txt
corner_cases_and_professional_touches.txt
