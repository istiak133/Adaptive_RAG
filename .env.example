# =====================================================================
# Adaptive Document Preparation System — Environment Variables
# =====================================================================
# 1. Copy this file to `.env`        :   cp .env.example .env
# 2. Replace every placeholder below with your real value.
# 3. NEVER commit .env to git (it's gitignored).
# =====================================================================


# ── LLM Provider API Keys ────────────────────────────────────────────
# Groq is the primary LLM provider (LLaMA 3.1 8B, fast, free tier).
# Sign up at: https://console.groq.com
# Free tier: 30 req/min, 14,400 req/day. Key format starts with "gsk_".
GROQ_API_KEY=gsk_replace_with_your_real_groq_key_here

# Google Gemini is the fallback provider (Gemini 1.5 Flash, 1M context).
# Sign up at: https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1M tokens/min, 1500 req/day. Format starts with "AIza".
GOOGLE_API_KEY=AIza_replace_with_your_real_gemini_key_here


# ── PostgreSQL (Docker Compose service) ──────────────────────────────
# These match the values in docker-compose.yml.
# Change POSTGRES_PASSWORD to anything; just keep DATABASE_URL in sync.
POSTGRES_DB=prep_kb
POSTGRES_USER=prep
POSTGRES_PASSWORD=prep_dev_change_me_in_production
DATABASE_URL=postgresql://prep:prep_dev_change_me_in_production@postgres:5432/prep_kb


# ── Ollama (optional, for offline / local LLM use) ───────────────────
# Uncomment + start Ollama locally if you want a third LLM fallback.
# Setup: https://ollama.com/download → ollama pull llama3:8b
# OLLAMA_BASE_URL=http://host.docker.internal:11434


# ── Application environment ──────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
